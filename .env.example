# gh-social-ml Environment Variables
# Copy this file to .env and fill in your values.

# GitHub Personal Access Token (required for acquisition)
GITHUB_TOKEN=your_github_token_here

# PostgreSQL Database URL (optional for the online API)
# ──────────────────────────────────────────────────────────────
# The feedback, onboarding, embedding, and recommendation API can start without
# DATABASE_URL. Configure it only for ingestion/trending jobs and the current
# optional Postgres-backed candidate metadata channels.
#
# Local PostgreSQL (Homebrew / native):
#   DATABASE_URL=postgresql://your_username@localhost:5432/gh_social
#
# Supabase (cloud):
#   DATABASE_URL=postgresql://postgres.xxxx:your-password@aws-0-region.pooler.supabase.com:6543/postgres
#
# SSL is auto-detected for Supabase hosts. No extra config needed.

# ──────────────────────────────────────────────────────────────
# Trending Repository Ingestion Configuration
# ──────────────────────────────────────────────────────────────

# Number of trending repositories to fetch per refresh cycle
TRENDING_REPO_LIMIT=30

# Refresh interval in hours (default: 24 hours)
TRENDING_REFRESH_HOURS=24

# PostgreSQL table names for trending repositories
TRENDING_TABLE_NAME=trending_repositories
TRENDING_METADATA_TABLE_NAME=trending_metadata

# Request timeout in seconds (for HTTP requests to GitHub Trending page)
GITHUB_TIMEOUT_SECONDS=30.0

# Maximum retry attempts for failed requests
GITHUB_MAX_RETRIES=4

# Log level for trending service
TRENDING_LOG_LEVEL=INFO

# Log file path (if not set, logs to stdout)
# TRENDING_LOG_FILE=/var/log/trending_service.log

# Whether to continue processing on individual repository failures
CONTINUE_ON_ERROR=true

# Maximum number of consecutive failures before stopping the pipeline
MAX_CONSECUTIVE_FAILURES=10
# DATABASE_URL=postgresql://your_username@localhost:5432/gh_social

# Migration / Sync settings (used by sync_local_to_supabase.py)
# ──────────────────────────────────────────────────────────────
# LOCAL_DATABASE_URL=postgresql://your_username@localhost:5432/gh_social
# SUPABASE_DATABASE_URL=postgresql://postgres.xxxx:your-password@aws-0-region.pooler.supabase.com:6543/postgres

# ──────────────────────────────────────────────────────────────
# Backend Integration
# ──────────────────────────────────────────────────────────────

# Shared secret accepted from the gh-social backend on every internal endpoint.
# Must match the backend deployment and contain at least 32 random bytes.
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=your-internal-api-secret-here

# Bounds retained feedback events in Redis Streams. Increase only after sizing
# Redis memory and retention requirements for production traffic.
FEEDBACK_STREAM_MAXLEN=1000000

# Reclaim unacknowledged events from crashed workers after this idle period.
FEEDBACK_CLAIM_IDLE_MS=60000

# Keep false in deployed environments. Set true only for local development
# where losing queued feedback on process restart is acceptable.
ALLOW_IN_MEMORY_FEEDBACK=false

# ──────────────────────────────────────────────────────────────
# Deployment Optimizations (Render, Railway, etc.)
# ──────────────────────────────────────────────────────────────

# Force pip to download the CPU-only version of PyTorch to save massive amounts of RAM
# PIP_EXTRA_INDEX_URL=https://download.pytorch.org/whl/cpu

# Limit PyTorch and its math libraries to 1 thread to prevent memory duplication 
# (These are already hardcoded in api/main.py, but good practice to set in your platform dashboard)
# OMP_NUM_THREADS=1
# OPENBLAS_NUM_THREADS=1
# MKL_NUM_THREADS=1
# VECLIB_MAXIMUM_THREADS=1
# NUMEXPR_NUM_THREADS=1

# Restrict Linux memory arenas to save idle RAM
# MALLOC_ARENA_MAX=2
